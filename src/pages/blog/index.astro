---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout title="Blog">
	<h1 class="text-3xl font-bold mb-8">Blog</h1>
	{posts.length === 0 && <p class="text-gray-400">No posts yet.</p>}
	<ul class="space-y-8">
		{posts.map(post => (
			<li>
				<a href={`/blog/${post.id}`} class="group block">
					<h2 class="text-xl font-semibold group-hover:underline">{post.data.title}</h2>
					<p class="text-sm text-gray-400 mt-1"><FormattedDate date={post.data.pubDate} /></p>
					<p class="text-gray-300 mt-2">{post.data.description}</p>
					{post.data.tags && post.data.tags.length > 0 && (
						<div class="flex flex-wrap gap-2 mt-2">
							{post.data.tags.map(tag => (
								<span class="badge badge-outline badge-sm">{tag}</span>
							))}
						</div>
					)}
				</a>
			</li>
		))}
	</ul>
</BaseLayout>
