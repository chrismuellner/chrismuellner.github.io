---
import BaseLayout from "../layouts/BaseLayout.astro";
import Talk from "../components/Talk.astro";

import { Image } from "astro:assets";
import speakerImage from "../assets/speaker.png";

import { getCollection } from "astro:content";

const talks = await getCollection("talks");
---

<BaseLayout title="About">
    <section class="mb-8">
        <h2 class="text-3xl font-extrabold">About Me</h2>
        <div class="flex flex-row justify-between">
            <p class="italic">
                Christoph is a Software Engineer with 5+ years experience
                working with Kubernetes.
            </p>
            <div class="flex-none">
                <Image
                    src={speakerImage}
                    alt="A picture of myself during a talk"
                    class="rounded-md size-32 border border-slate-400 shadow-inner"
                />
            </div>
        </div>
    </section>

    <div
        class="mb-8 rounded-lg border border-blue-300 bg-blue-50 p-4 text-blue-900 dark:border-blue-700 dark:bg-blue-950 dark:text-blue-100"
    >
        For my full work history and education, visit my{" "}
        <a
            href="https://www.linkedin.com/in/christoph-muellner-at/"
            class="font-semibold underline hover:text-blue-600 dark:hover:text-blue-300"
            target="_blank"
            rel="noopener noreferrer">LinkedIn profile</a
        >.
    </div>

    <section>
        <h2 class="text-3xl font-extrabold">Talks</h2>
        <ul>
            {talks.reverse().map((talk) => <Talk talk={talk} />)}
        </ul>
    </section>
</BaseLayout>
