---
import BaseLayout from '../layouts/BaseLayout.astro';
import Social from '../components/Social.astro';
import BlogCard from '../components/BlogCard.astro';

import { Image } from 'astro:assets';
import profileImage from '../assets/profile.png';

import { getCollection } from 'astro:content';
import { AUTHOR } from '../consts';

const latestPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
	.slice(0, 1);
---

<BaseLayout>
	<section class="flex flex-row justify-between mb-4">
		<div>
			<p class="py-1">👋 Hi, I'm</p>
			<h1 class="text-4xl text-slate-400">{ AUTHOR }</h1>
			<p class="py-1">a Software Engineer from Austria 🇦🇹</p>
		</div>
		<Image src={profileImage} alt="A headshot of myself" class="rounded-full size-32 border border-slate-400 shadow-inner" />
	</section>

	<section>
		<ul class="flex flex-wrap gap-1.5">
			<Social name="Github" url="https://github.com/chrismuellner" icon="github" />
			<Social name="Linkedin" url="https://www.linkedin.com/in/christoph-muellner-at" icon="linkedin" />
		</ul>
	</section>

	{latestPosts.length > 0 && (
		<section class="mt-8">
			<div class="flex justify-between items-center mb-4">
				<h2 class="text-2xl font-bold">Latest Post</h2>
				<a href="/blog" class="text-sm text-primary hover:underline">See all →</a>
			</div>
			<ul class="space-y-4">
				{latestPosts.map(post => (
					<li>
						<BlogCard
							title={post.data.title}
							pubDate={post.data.pubDate}
							tags={post.data.tags}
							href={`/blog/${post.id}`}
						/>
					</li>
				))}
			</ul>
		</section>
	)}
</BaseLayout>
