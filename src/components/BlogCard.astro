---
import FormattedDate from './FormattedDate.astro';

interface Props {
	title: string;
	pubDate: Date;
	tags?: string[];
	href: string;
}

const { title, pubDate, tags = [], href } = Astro.props;
---

<a href={href} class="block group">
	<div class="bg-base-200 border border-base-300 rounded-xl p-7 transition-colors group-hover:border-base-content/20 group-hover:bg-base-300">
		<h2 class="text-2xl font-bold mb-5 group-hover:text-primary transition-colors">{title}</h2>
		<dl class="grid grid-cols-[auto_1fr] gap-x-8 gap-y-1.5 text-sm">
			<dt class="text-base-content/40 font-semibold tracking-widest uppercase text-xs self-center">Published</dt>
			<dd class="text-base-content/70"><FormattedDate date={pubDate} /></dd>
			{tags.length > 0 && (
				<>
					<dt class="text-base-content/40 font-semibold tracking-widest uppercase text-xs self-center">Tags</dt>
					<dd class="text-base-content/70">{tags.map(t => t.toUpperCase()).join(' • ')}</dd>
				</>
			)}
		</dl>
	</div>
</a>
