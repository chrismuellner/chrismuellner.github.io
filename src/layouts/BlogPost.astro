---
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';

interface ChangelogEntry {
	date: Date;
	note: string;
}

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	tags?: string[];
	changelog?: ChangelogEntry[];
	ogImage?: string;
	headings?: MarkdownHeading[];
}

const { title, description, pubDate, updatedDate, tags, changelog, ogImage, headings } = Astro.props;
---

<BaseLayout title={title} description={description} image={ogImage}>
	<article class="prose prose-invert max-w-none">
		<div class="mb-6">
			<h1 class="text-3xl font-bold mb-2">{title}</h1>
			<div class="text-sm text-gray-400 flex flex-wrap gap-x-4 gap-y-1">
				<span>Published <FormattedDate date={pubDate} /></span>
				{updatedDate && <span>Updated <FormattedDate date={updatedDate} /></span>}
			</div>
			{tags && tags.length > 0 && (
				<div class="flex flex-wrap gap-2 mt-3">
					{tags.map(tag => (
						<span class="badge badge-outline badge-sm">{tag}</span>
					))}
				</div>
			)}
		</div>

		{headings && headings.length > 0 && (
			<nav class="mb-8 p-4 rounded border border-gray-700 not-prose">
				<p class="font-semibold mb-2 text-sm">Table of Contents</p>
				<ul class="space-y-1 text-sm">
					{headings.map(h => (
						<li style={`padding-left: ${(h.depth - 2) * 1}rem`}>
							<a href={`#${h.slug}`} class="text-gray-400 hover:text-white">{h.text}</a>
						</li>
					))}
				</ul>
			</nav>
		)}

		<slot />

		{changelog && changelog.length > 0 && (
			<section class="mt-12 border-t border-gray-700 pt-6">
				<h2 class="text-lg font-semibold mb-3">Changelog</h2>
				<ul class="space-y-2 text-sm">
					{changelog.map(entry => (
						<li class="flex gap-3">
							<span class="text-gray-400 shrink-0"><FormattedDate date={entry.date} /></span>
							<span>{entry.note}</span>
						</li>
					))}
				</ul>
			</section>
		)}
	</article>
</BaseLayout>
